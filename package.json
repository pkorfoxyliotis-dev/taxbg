{
  "name": "taxbg-services",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "dev:stop": "powershell -Command \"$p = (Get-NetTCPConnection -LocalPort 3002 -State Listen -EA 0).OwningProcess; if ($p) { taskkill /PID $p /F; Write-Host 'Stopped TaxBG on port 3002' } else { Write-Host 'Nothing on port 3002' }\"",
    "build": "next build",
    "postbuild": "node scripts/generate-llms.mjs",
    "start": "next start",
    "lint": "eslint",
    "agent:llms": "node scripts/generate-llms.mjs",
    "images:sliders": "node scripts/optimize-slider-images.mjs",
    "reviews:import": "node scripts/import-published-reviews.mjs",
    "brand:assets": "node scripts/optimize-brand-assets.mjs"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^18.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
